    "@bull-board/nestjs": "^6.5.3",
    "@google-cloud/vertexai": "^1.9.0",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
