    "dayjs": "^1.11.13",
    "marked": "^16.3.0",
    "mongoose": "^8.7.3",
    "multer": "^2.0.2",
    "nestjs-zod": "^4.1.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
