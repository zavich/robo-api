{
  "family": "robo-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "8192",

  "executionRoleArn": "arn:aws:iam::339340413604:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::339340413604:role/robo-task-role",

  "containerDefinitions": [
    {
      "name": "robo-api",
      "image": "REPLACE_AT_DEPLOY",
      "essential": true,

      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],

      "secrets": [
        {
          "name": "API_KEY_MASTER",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:339340413604:secret:robo-api/prod:API_KEY_MASTER::"
        },
        {
          "name": "JWT_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:339340413604:secret:robo-api/prod:JWT_SECRET_KEY::"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:339340413604:secret:robo-api/prod:DATABASE_URL::"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/robo-api",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
